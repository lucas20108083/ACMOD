[hiddenAction_Ai处理HFEF]
autoTrigger:if self.isControlledByAI() and rnd(1, 9) >= 1 and rnd(1, 9) <= 3 and not self.hasFlag(id=1) and self.timeAlive() > 5
temporarilyAddTags: hfef
temporarilyRemoveTags: tumor,void
[hiddenAction_Ai处理Tumor]
autoTrigger:if self.isControlledByAI() and rnd(1, 9) >= 3 and rnd(1, 9) <= 6 and not self.hasFlag(id=1) and self.timeAlive() > 5
temporarilyAddTags: tumor
temporarilyRemoveTags: hfef,void
[hiddenAction_Ai处理Void]
autoTrigger:if self.isControlledByAI() and rnd(1, 9) >= 6 and rnd(1, 9) <= 9 and not self.hasFlag(id=1) and self.timeAlive() > 5
temporarilyAddTags: void
temporarilyRemoveTags: hfef,tumor


