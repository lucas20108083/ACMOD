[core]



name:光束虚空塔T2
displayText:buckled lightshooter
displayText_zh:超载魔光
displayDescription:终结
mass:9000
maxHp:1200
radius:50
class: CustomUnitMetadata
techLevel:2
maxShield:800
buildSpeed:30s
isBio:false
buildingToFootprintOffsetX:40
buildingToFootprintOffsetY:40
price:2300,VE:3400
constructionFootprint:0,0,3,3
footprint:0,0,3,3
isBuilding:true
[graphics]
#teamColorsOnTurret:true
#teamColoringMode:hueShift
imageScale:1.25
image:超载魔光底座.png
image_back:back.png
image_turret:buckledlightshooter.png
turretImageScale:1
image_wreak:死了的超载魔光.png
[attack]
canAttack: true
canAttackFlyingUnits: true
canAttackLandUnits:   false
canAttackUnderwaterUnits: false
turretSize: 28
turretTurnSpeed: 6
maxAttackRange: 315
shootDelay: 0.75s
[turret_1]
x: 0
y: 20
shoot_sound:plasma_fire
shoot_sound_vol:0.3
shoot_flame:small
shoot_light:#FFEECCCC
recoilOffset: -0.3
recoilOutTime: 3
recoilReturnTime: 8
[projectile_1]
areaDamage: 205
areaRadius:325
directDamage: 215
life: ${60*3}
instant:true
areaHitAirAndLandAtSameTime:true
areaHitUnderwaterAlways:true
areaExpandTime:290
flameWeapon:true
laserEffect:true
lightColor:#ff0000
color:#500000ff
lightSize:1
#instantReuseLast:true
[movement]
movementType:none